{
  "name": "sing-sub",
  "private": true,
  "version": "3.0.0",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "typecheck:shared": "tsc -p tsconfig.shared.json",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "typecheck:worker": "tsc -p tsconfig.worker.json",
    "typecheck": "npm run typecheck:shared && npm run typecheck:web && npm run typecheck:worker",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test": "npm run test:unit && npm run test:integration",
    "build": "npm run typecheck && vite build",
    "worker:dry-run": "npm run build && wrangler deploy --dry-run",
    "verify": "npm run lint && npm run typecheck && npm run test && vite build && npm run test:e2e",
    "preview": "wrangler dev",
    "deploy:cloudflare": "node scripts/deploy-cloudflare.mjs",
    "deploy": "npm run build && npm run deploy:cloudflare"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@primeuix/themes": "^2.0.3",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "primevue": "^4.5.5",
    "vue": "^3.5.32",
    "vue-i18n": "^11.4.6",
    "vue-router": "^4.6.4",
    "vuedraggable": "^4.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.4",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.2.6",
    "wrangler": "^4"
  }
}
